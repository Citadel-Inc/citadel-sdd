{
  "name": "@rethunk/citadel-sdd",
  "version": "0.5.0",
  "description": "MCP stdio server wrapping the Spec-Driven Development lifecycle for agent workflows.",
  "type": "module",
  "private": false,
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "docs",
    "AGENTS.md",
    "HUMANS.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "citadel-sdd": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json && mkdir -p dist/profile && cp src/profile/*.yaml dist/profile/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "bun test src/ tests/",
    "test:coverage": "bun test src/ tests/ --coverage",
    "lint:citadel-parity": "bun scripts/lint-citadel-parity.ts",
    "setup-hooks": "git config core.hooksPath .githooks"
  },
  "keywords": [
    "mcp",
    "spec-driven-development",
    "sdd",
    "model-context-protocol",
    "stdio",
    "llm",
    "agent-workflow",
    "bastion",
    "citadel"
  ],
  "author": "Rethunk-AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rethunk-AI/citadel-sdd.git"
  },
  "bugs": {
    "url": "https://github.com/Rethunk-AI/citadel-sdd/issues"
  },
  "homepage": "https://github.com/Rethunk-AI/citadel-sdd#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.6.2",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@hono/node-server": "^1.19.14",
    "hono": "^4.12.18",
    "fast-uri": "^3.1.2",
    "postcss": "^8.5.10",
    "vite": "^7.3.2",
    "ip-address": "^10.1.1"
  }
}
